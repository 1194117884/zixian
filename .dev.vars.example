# Never commit actual secrets. Copy this file to .dev.vars for local development.
# Cloudflare production values use `wrangler secret put <NAME>` or the Worker dashboard.

# Required security and authentication secrets
AUTH_PEPPER=
RESEND_API_KEY=

# Model-provider secrets (enable only the providers you offer)
DEEPSEEK_API_KEY=
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# Optional provider endpoint overrides for OpenAI-compatible gateways
DEEPSEEK_BASE_URL=
OPENAI_BASE_URL=
ANTHROPIC_BASE_URL=

# Non-secret runtime configuration
RESEND_FROM=字见 <login@auth.example.com>
APP_ORIGIN=http://localhost:4173

# Test-only: enables the fake Stripe success flow. Never use this for real payments.
PAYMENTS_MODE=test
